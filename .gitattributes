# Normalize all text files to LF on checkout and commit so Prettier's
# `endOfLine: "lf"` setting stays consistent across macOS, Linux and Windows.
* text=auto eol=lf

# Binary assets — never touch line endings.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.svg   text
*.ico   binary
*.mp3   binary
*.wav   binary
*.ogg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
